{
  "manifest_version": 3,
  "name": "Fake Job Detector",
  "version": "2.0",
  "description": "Automatically detects fake jobs and internships with memory-based fraud detection.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
